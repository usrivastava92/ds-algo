#!/usr/bin/env sh
# Git pre-commit hook that runs spotlessApply on staged java files, then re-adds them.
# Generated by Gradle task 'installSpotlessHook'.

echo 'Running Spotless Apply before commit...'
./gradlew spotlessApply --no-daemon
status=$?
if [ $status -ne 0 ]; then
  echo 'Spotless Apply failed. Commit aborted.' >&2
  exit $status
fi

# Optionally add changed files back to staging.
# This can be useful if spotlessApply modified files.

git diff --name-only --diff-filter=ACM -- '*.java' | while read -r file; do
  if [ -n "$file" ]; then
    git add "$file"
  fi
done

exit 0
